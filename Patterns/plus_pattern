#include<stdio.h>
int main(){
    int n=5;
    int sum=0;
    int m;
    for(int i=1;i<=n;i++){
        sum=i+sum;

    }
    m=sum/n;
    for(int i=1;i<=n;i++){
        for(int j=1;j<=n;j++){
            if(i==m || j==m){
                printf("* ");
            }
            else{
                printf("  ");
            }
        }
        printf("\n");
    }



}
